# Database
DATABASE_URL=postgresql+asyncpg://progressors:progressors@postgres:5432/progressors
POSTGRES_USER=progressors
POSTGRES_PASSWORD=progressors
POSTGRES_DB=progressors
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000

# LLM Configuration - HTTP API MODE
USE_LOCAL_LLM=false
INSTALL_LOCAL_LLM=false
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
API_LLM=http://host.docker.internal:8080/dump

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org

# Prompts
PROMPT_FILE_PATH=/app/INSTUC.txt

# Timeouts
LLM_TIMEOUT_SECONDS=120
