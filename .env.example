# Database
POSTGRES_USER=progressors
POSTGRES_PASSWORD=progressors
POSTGRES_DB=progressors
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
PUBLIC_BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:8080
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?|https://.*\.vercel\.app

# LLM
LLM_PROVIDER=gemini
LLM_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.2
LLM_JSON_MODE=true
USE_LOCAL_LLM=false
INSTALL_LOCAL_LLM=false
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
API_LLM=http://host.docker.internal:8080/dump
LLM_TIMEOUT_SECONDS=120

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
WEBAPP_URL=http://localhost:5173

# Frontend
WEB_PORT=5173
VITE_ALLOWED_HOSTS=.ngrok-free.dev,.ngrok-free.app
VITE_DEV_TELEGRAM_ID=123
