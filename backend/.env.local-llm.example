# Local LLM Configuration Example
# Copy to .env and set USE_LOCAL_LLM=true to use local Qwen model

# Use local LLM instead of HTTP API
USE_LOCAL_LLM=true

# HuggingFace model identifier (must be compatible with transformers library)
# Tested with: Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Keep API_LLM configured for fallback (not used when USE_LOCAL_LLM=true)
API_LLM=http://localhost:8080/dump

# Database connection
DATABASE_URL=postgresql+asyncpg://progressors:progressors@postgres:5432/progressors

# Telegram bot token (optional)
TELEGRAM_BOT_TOKEN=

# Path to prompt templates file
PROMPT_FILE_PATH=/app/INSTUC.txt

# LLM timeout in seconds
LLM_TIMEOUT_SECONDS=120
